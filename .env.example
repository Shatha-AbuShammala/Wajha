# ==============================================================================
# Wajha Local Environment Variables Config Template
# Copy this file to a new file named '.env' in the same folder and fill in details.
# DO NOT commit the actual '.env' file to Git!
# ==============================================================================

# Django configuration
DEBUG=True
SECRET_KEY=django-insecure-change-this-to-a-secure-random-key-in-production

# ── Database Configuration ────────────────────────────────────────────────────
# Default engine is MySQL. Switch to sqlite for quick local dev (no server needed).

DB_ENGINE=mysql
DB_NAME=grantpal
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_HOST=127.0.0.1
DB_PORT=3306

# SQLite alternative (comment out the MySQL block above and uncomment below):
# DB_ENGINE=sqlite
# DB_NAME=db.sqlite3

# AI Engine Credentials
ANTHROPIC_API_KEY=your_claude_api_key_here

# Google OAuth (optional - for social login)
# To get these: console.cloud.google.com
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# GitHub OAuth (optional - for social login)
# To get these: github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here
